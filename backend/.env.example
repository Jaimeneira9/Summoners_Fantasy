# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # solo backend, nunca exponer al frontend

# Riot Games API
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Pipeline
BACKEND_URL=http://localhost:8000                # URL del worker para keep-alive
# LEAGUEPEDIA_TOURNAMENT=LEC/2026 Season/Spring Season  # override manual (normalmente vacío)
# ORACLES_ELIXIR_CSV_URL=                              # fallback si S3 discovery falla

# App
ENVIRONMENT=development     # development | production
FRONTEND_URL=http://localhost:3000
# ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000  # comma-separated; overrides FRONTEND_URL if set
